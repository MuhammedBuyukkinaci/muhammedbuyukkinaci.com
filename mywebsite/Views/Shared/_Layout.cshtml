<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Muhammed Büyükkınacı</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/css/bootstrap.min.css"
        crossorigin="anonymous">
    <script src="https://kit.fontawesome.com/6839b859a8.js" crossorigin="anonymous"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
    <link rel="stylesheet" href="~/css/index.css" />
    <link rel="stylesheet" href="~/css/contact.css" />
    <link rel="stylesheet" href="~/css/photos.css" />
    <link rel="stylesheet" href="~/css/projects.css" />


    <script src="https://code.jquery.com/jquery-3.5.1.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.min.js"crossorigin="anonymous"></script>

    
</head>

<body>

    <header>

        <div id="header_left" class="row">
            <div id="myname" class="col-sm-2">

                <div class="mt-4" style="display: flex; justify-content: center;">
                    <a class="btn" asp-area="" asp-controller="Home" asp-action="Index">
                        <i id="my_home_button" class="fas fa-home fa-3x" style="color: white;"></i>
                    </a>
                </div>

            </div>

            <div id="header_center" class="col-sm-8">

                <nav class="navbar navbar-expand-xl navbar-toggleable-xl navbar-light border-bottom box-shadow mb-3">
                    <div class="container">

                        <button class="navbar-toggler" type="button" data-toggle="collapse"
                            data-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false"
                            aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="navbar-collapse collapse d-xl-inline-flex flex-xl-row-reverse my-4">
                            <ul class="container navbar-nav" id="navbar_ul">
                                <li class="nav-item">
                                    <a class="list-group-item-action nav-link list-group-item-secondary rounded text-center mx-2 not-go-to-new-line"
                                        asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                                </li>
                                <li class="nav-item">
                                    <a class="list-group-item-action nav-link list-group-item-success rounded text-center mx-2 not-go-to-new-line"
                                        asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                                </li>
                                <li class="nav-item">
                                    <a class="list-group-item-action nav-link list-group-item-danger rounded text-center mx-2 not-go-to-new-line"
                                        asp-area="" asp-controller="Home" asp-action="YouKnowMe">You Know Me?</a>
                                </li>
                                <li class="nav-item">
                                    <a class="list-group-item-action nav-link list-group-item-warning rounded text-center mx-2 not-go-to-new-line"
                                        asp-area="" asp-controller="Home" asp-action="Testimonials">Testimonials</a>
                                </li>
                                <li class="nav-item">
                                    <a class="list-group-item-action nav-link list-group-item-info rounded text-center mx-2 not-go-to-new-line"
                                        asp-area="" asp-controller="Home" asp-action="Photos">Photos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="list-group-item-action nav-link list-group-item-primary rounded text-center mx-2 not-go-to-new-line"
                                        asp-area="" asp-controller="Home" asp-action="Projects">Projects</a>
                                </li>
                                <li class="nav-item">
                                    <a class="list-group-item-action nav-link list-group-item-dark rounded text-center mx-2 not-go-to-new-line"
                                        asp-area="" asp-controller="Home" asp-action="MonetaryMetrics">Monetary
                                        Metrics</a>
                                </li>

                            </ul>
                        </div>
                    </div>


                </nav>

            </div>

            <div id="header_right" class="col-sm-2">

            </div>

        </div>


    </header>

    <main>
        <div class="row">
            <div id="main_left" class="col-sm-2">
                <div class="container">
                    @await Html.PartialAsync("_sidebar")
                </div>
            </div>

            <div id="main_center" class="col-sm-8">

                <div class="container">
                    <main role="main" class="pb-3">

                        @RenderBody()

                    </main>
                </div>

            </div>

            <div id="main_right" class="col-sm-2">

            </div>

        </div>
    </main>

    <footer class="footer ">

        <div class="row">
            <div id="footer_left" class="col-sm-2">

            </div>

            <div id="footer_center" class="col-sm-8 text-muted border-top box-shadow">

                <div class="">

                    <div class="container text-center">
                        &copy; @DateTime.Now.Year -
                        Muhammed Büyükkınacı -
                        All rights reserved -
                        <a asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                    </div>

                </div>

            </div>

            <div id="footer_right" class="col-sm-2">

            </div>

        </div>
    </footer>

    

    <script src="~/js/colorizer.js" asp-append-version="true"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @RenderSection("onebyone", required: false)

    @RenderSection("youknowme", required: false)
</body>

</html>
